{
  "name": "apprunners",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "turbo build",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "pnpm --filter @apprunners/api db:migrate",
    "db:push": "pnpm --filter @apprunners/db db:push",
    "db:seed": "pnpm --filter @apprunners/db db:seed",
    "db:studio": "pnpm --filter @apprunners/db db:studio",
    "db:up": "docker compose up -d",
    "dev": "turbo dev --filter=@apprunners/api --filter=@apprunners/mobile",
    "dev:api": "turbo dev --filter=@apprunners/api",
    "dev:landing": "turbo dev --filter=@apprunners/landing",
    "dev:mobile": "turbo dev --filter=@apprunners/mobile"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.9.6"
  }
}
