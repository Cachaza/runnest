{
  "name": "apprunners",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "build": "pnpm -r build",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "pnpm --filter @apprunners/api db:migrate",
    "db:push": "pnpm --filter @apprunners/db db:push",
    "db:seed": "pnpm --filter @apprunners/db db:seed",
    "db:studio": "pnpm --filter @apprunners/db db:studio",
    "db:up": "docker compose up -d",
    "dev": "sh -c 'pnpm dev:api & api_pid=$!; trap \"kill $api_pid 2>/dev/null\" EXIT INT TERM; pnpm dev:mobile'",
    "dev:api": "pnpm --filter @apprunners/api dev",
    "dev:mobile": "pnpm --filter @apprunners/mobile start"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
